{
  "name": "batch-rename-tool",
  "version": "1.0.0",
  "description": "一个使用纯 TypeScript 编写的文件批量重命名工具，支持模板模式、替换、大小写转换、加前缀后缀等操作，执行前总是预览并需要确认。",
  "main": "dist/index.js",
  "bin": {
    "batch-rename": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "keywords": ["typescript", "cli", "rename", "batch", "file", "tool"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
