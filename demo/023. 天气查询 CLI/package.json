{
  "name": "weather-cli",
  "version": "1.0.0",
  "description": "一个使用纯 TypeScript 编写的命令行天气查询工具，支持实时天气、7日预报、多城市查询等功能。",
  "main": "dist/index.js",
  "bin": {
    "weather-cli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "keywords": [
    "typescript",
    "cli",
    "weather",
    "forecast"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
