{
  "name": "image-converter",
  "version": "1.0.0",
  "description": "一个使用纯 TypeScript 编写的图片格式转换工具，支持 PPM (P3/P6)、PGM (P2/P5)、PBM (P1/P4) 与 BMP (24 位) 格式的读取、写入、转换与缩放。",
  "main": "dist/index.js",
  "bin": {
    "imgconv": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "keywords": [
    "typescript",
    "cli",
    "image",
    "convert",
    "ppm",
    "pgm",
    "pbm",
    "bmp"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
