{
  "name": "qr-code-generator",
  "version": "1.0.0",
  "description": "一个使用纯 TypeScript 编写的简易二维码生成器，实现版本 1-3 的字节模式编码、Reed-Solomon 纠错、掩码选择，并以 ASCII 字符在终端中输出二维码矩阵。",
  "main": "dist/index.js",
  "bin": {
    "qr-gen": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "keywords": ["typescript", "cli", "qrcode", "qr", "generator", "reed-solomon", "ascii"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
