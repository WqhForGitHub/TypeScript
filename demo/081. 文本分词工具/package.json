{
  "name": "text-tokenizer",
  "version": "1.0.0",
  "description": "一个使用纯 TypeScript 编写的文本分词工具，支持空白/字符/词典/N-gram 等多种分词模式。",
  "main": "dist/index.js",
  "bin": {
    "text-tokenizer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "keywords": [
    "typescript",
    "text",
    "tokenizer",
    "nlp",
    "chinese"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
